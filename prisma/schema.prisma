generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model activity_log {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  company_id Int?
  user_name  String?   @db.VarChar(255)
  message    String?   @db.VarChar(255)
  type       String?   @db.VarChar(255)
  log_id     Int?
  log_type   String?   @db.VarChar(255)
  date_time  DateTime? @db.Timestamp(0)
  created_at DateTime  @default(now()) @db.Timestamp(0)
  updated_at DateTime? @default(now()) @db.Timestamp(0)
  deleted_at DateTime? @db.Timestamp(0)
}

model adv_tour_diary {
  id              Int               @id @default(autoincrement()) @db.UnsignedInt
  user_id         Int
  tour_date       DateTime          @db.Date
  status          String            @default("active") @db.VarChar(255)
  start           DateTime?         @db.DateTime(0)
  end             DateTime?         @db.DateTime(0)
  start_lat       Decimal?          @db.Decimal(10, 8)
  start_lng       Decimal?          @db.Decimal(10, 8)
  end_lat         Decimal?          @db.Decimal(10, 8)
  end_lng         Decimal?          @db.Decimal(10, 8)
  company_id      Int?
  created_at      DateTime          @default(now()) @db.Timestamp(0)
  updated_at      DateTime?         @db.Timestamp(0)
  deleted_at      DateTime?         @db.Timestamp(0)
  users           users             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "user_id_foreign_adv_tour_diary")
  adv_tour_visits adv_tour_visits[]

  @@index([user_id], map: "user_id_foreign_adv_tour_diary")
}

model adv_tour_visits {
  id             Int            @id @default(autoincrement())
  tour_id        Int            @db.UnsignedInt
  user_id        Int?
  visit_time     DateTime       @db.Time(0)
  location_name  String         @db.Text
  purpose        String         @db.Text
  latitude       Decimal?       @db.Decimal(10, 8)
  longitude      Decimal?       @db.Decimal(10, 8)
  observations   String?        @db.Text
  photo_path     String?        @db.Text
  company_id     Int?
  created_at     DateTime       @default(now()) @db.Timestamp(0)
  updated_at     DateTime?      @db.Timestamp(0)
  deleted_at     DateTime?      @db.Timestamp(0)
  adv_tour_diary adv_tour_diary @relation(fields: [tour_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "adv_tour_id_foreign_adv_tou_visits")
  users          users?         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "user_id_foreign_adv_tour_visits")

  @@index([tour_id], map: "adv_tour_id_foreign_adv_tou_visits")
  @@index([user_id], map: "user_id_foreign_adv_tour_visits")
}

